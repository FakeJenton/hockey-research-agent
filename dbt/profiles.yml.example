# Copy to profiles.yml (gitignored) and fill in your project + keyfile path.
hockey_research_agent:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      keyfile: /absolute/path/to/gcp-sa.json
      project: your-gcp-project-id
      dataset: nhl_stg
      location: US
      threads: 4
      job_execution_timeout_seconds: 300
